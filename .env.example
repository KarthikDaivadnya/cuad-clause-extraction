# Copy this file to `.env` and fill in the key(s) for whichever provider(s) you use.
# You only need ONE provider's key to run the pipeline (default: groq).

LLM_PROVIDER=groq

# --- Groq (default — free tier, fast) ---------------------------------
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenAI (optional, used for --provider openai or compare_models.py) --
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (optional) ----------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
